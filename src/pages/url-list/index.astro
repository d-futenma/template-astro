    +media('md')
      max-width 960px

  .url-list-heading
    font-vw-set(30, 30)
    font-weight bold
    margin-bottom vw-sm(25)
    text-align center
    +media('md')
      font-rem-set(20)
      margin-bottom 20px

  .url-list
    border 1px solid #D7D7D7
    border-radius 10px
    overflow hidden

  .url-list-item
    font-vw-set(30)
    background #FAFAFB
    word-break break-all
