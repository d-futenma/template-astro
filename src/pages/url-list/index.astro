---
const allPages = await Astro.glob('/src/pages/**/*.astro'); 
let pathList = [];

const changeExtension = (filename) => filename.replace(/\.astro$/, '.html')

const extractPath = (fullPath) => {
  let path = fullPath.split('/src/pages/')[1];
  return changeExtension(path);
}

const generateUrl = async (page) => {
  let url = page.url ? page.url : '/';

  if (page.getStaticPaths) {
    const paths = await page.getStaticPaths();

    paths.forEach(path => {
      const dynamicSegmentMatch = page.file.match(/\[\.\.\.(.+?)\]\.astro$/);
      if (dynamicSegmentMatch) {
        const dynamicSegment = dynamicSegmentMatch[1];
        url = `/${path.params[dynamicSegment]}`;
      }
      pathList.push({ ...page, url, path: `${url}.html` });
    });
  } else {
    pathList.push({ ...page, url, path: extractPath(page.file) });
  }
}

await Promise.all(allPages.map(generateUrl));
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>URL LIST</title>
  </head>
  <body class="page-url-list">
    <div class="url-list-content">
      <h1 class="url-list-heading">URL LIST</h1>
      <ul class="url-list">
        {pathList.map((item) => (
          <li class="url-list-item"><a class="url-list-link" href={item.url}><span class="url-list-label">{item.path}</span></a></li>
        ))}
      </ul>
    </div>
  </body>
</html>

<style lang="stylus">
  .page-url-list
    background-color #F5F5F5
    color #333333
    font-family 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif
