---
import Layout from "@/layouts/Layout.astro";
import { pathImg } from "@/consts";
import Img from "@/components/ui/Img.astro";

const title = "Home";
const description = "Homeディスクリプション";
const bodyClass = "page-home";
---
<Layout title={title} description={description} bodyClass={bodyClass}>
  <div class="dummy-gallery">
    <div class="dummy-gallery-items">
      {
        [...Array(14).keys()].map((i) => (
          <div class={`dummy-gallery-item-${i + 1} dummy-gallery-item`}><Img src={`${pathImg}dummy/img-${i + 1}.webp`} alt="" /></div>
        ))
      }
    </div>
  </div>
</Layout>

<style lang="stylus">
  .dummy-gallery
    size 100% 100vh

  .dummy-gallery-items
    display grid
    gap vw-sm(20)
    grid-template-columns repeat(16, 1fr)
    grid-template-rows repeat(14, 1fr)
    padding vw-sm(10) vw-sm(20)
    width 100%

    +media('md')
      gap 40px
      height 150vh
      padding 20px 40px

  .dummy-gallery-item
    img
      object-fit cover
      size 100%

  .dummy-gallery-item-1
    grid-column 1 / 6
    grid-row 1 / 6

  .dummy-gallery-item-2
    grid-column 6 / 9
    grid-row 1 / 11

  .dummy-gallery-item-3
    grid-column 9 / 12
    grid-row 1 / 4

  .dummy-gallery-item-4
    grid-column 12 / -1
    grid-row 1 / 4

  .dummy-gallery-item-5
    grid-column 1 / 4
    grid-row 6 / 11

  .dummy-gallery-item-6
    grid-column 4 / 6
    grid-row 6 / 7

  .dummy-gallery-item-7
    grid-column 4 / 6
    grid-row 7 / 11

  .dummy-gallery-item-8
    grid-column 1 / 6
    grid-row 11 / -1

  .dummy-gallery-item-9
    grid-column 6 / 12
    grid-row 11 / -1

  .dummy-gallery-item-10
    grid-column 9 / 12
    grid-row 4 / 11

  .dummy-gallery-item-11
    grid-column 12 / 14
    grid-row 4 / 6

  .dummy-gallery-item-12
    grid-column 14 / -1
    grid-row 4 / 6

  .dummy-gallery-item-13
    grid-column 12 / -1
    grid-row 6 / 13

  .dummy-gallery-item-14
    grid-column 12 / -1
    grid-row 13 / -1

  .heading
    calc-aspect-ratio(650, 28)
    fill #ffffff
    fixed top 50% left 50%
    overflow hidden
    transform translate(-50%, -50%)
    width vw-sm(650)
    z-index 100

    +media('md')
      calc-aspect-ratio(900, 39)
      width vw-md(900)
</style>
