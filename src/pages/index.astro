---
import Layout from "@/layouts/Layout.astro";
import { pathImg } from "@/consts";
import Img from "@/components/ui/Img.astro";
import Modal from "@/components/ui/Modal.astro";

const title = "Home";
const description = "Homeディスクリプション";
const bodyClass = "page-home";
---
<Layout title={title} description={description} bodyClass={bodyClass}>
  <Fragment slot="main">
    <div class="modal-trigger" aria-label="モーダルウィンドウを開く" data-modal-trigger data-modal-target="video-1">video-1</div>
    <div class="modal-trigger" aria-label="モーダルウィンドウを開く" data-modal-trigger data-modal-target="video-2">video-2</div>

    {/* dummy */}
    <div class="dummy-gallery">
      <div class="dummy-gallery-items">
        {
          [...Array(14).keys()].map((i) => (
            <div class={`dummy-gallery-item-${i + 1} dummy-gallery-item`}><Img src={`${pathImg}dummy/img-${i + 1}.webp`} alt="" /></div>
          ))
        }
      </div>
    </div>
    {/* dummy */}
  </Fragment>

  <Fragment slot="modal">
    <Modal modalId="video-1">
      <div class="modal-content">
        <p>video-1</p>
        <div class="video" data-youtube>
          <div class="video-thumb" data-youtube-thumb><Img src="https://placehold.jp/B3C7FF/B3C7FF/640x480.png" alt="" style="width: 100%;" /></div>
          <div class="video-player" data-youtube-id="iCbqQrxwEEE"></div>
        </div>
      </div>
    </Modal>

    <Modal modalId="video-2">
      <div class="modal-content">
        <p>video-2</p>
        <div data-youtube>
          <div data-youtube-thumb><Img src="https://placehold.jp/B3C7FF/B3C7FF/640x480.png" alt="" style="width: 100%;" /></div>
          <div data-youtube-id="FPx68UiiBr8"></div>
        </div>
    </Modal>
  </Fragment>
</Layout>

{/* dummy */}
<style lang="stylus">
  .modal-trigger
    padding 0 10px
  .dummy-gallery-items
    display grid
    gap vw-sm(20)
    grid-template-columns repeat(16, 1fr)
    grid-template-rows repeat(14, 1fr)
    padding vw-sm(10) vw-sm(20)
    width 100%

    +media('md')
      gap 40px
      height 150vh
      padding 20px 40px

  .dummy-gallery-item
    img
      object-fit cover
      size 100%

  .dummy-gallery-item-1
    grid-column 1 / 6
    grid-row 1 / 6

  .dummy-gallery-item-2
    grid-column 6 / 9
    grid-row 1 / 11

  .dummy-gallery-item-3
    grid-column 9 / 12
    grid-row 1 / 4

  .dummy-gallery-item-4
    grid-column 12 / -1
    grid-row 1 / 4

  .dummy-gallery-item-5
    grid-column 1 / 4
    grid-row 6 / 11

  .dummy-gallery-item-6
    grid-column 4 / 6
    grid-row 6 / 7

  .dummy-gallery-item-7
    grid-column 4 / 6
    grid-row 7 / 11

  .dummy-gallery-item-8
    grid-column 1 / 6
    grid-row 11 / -1

  .dummy-gallery-item-9
    grid-column 6 / 12
    grid-row 11 / -1

  .dummy-gallery-item-10
    grid-column 9 / 12
    grid-row 4 / 11

  .dummy-gallery-item-11
    grid-column 12 / 14
    grid-row 4 / 6

  .dummy-gallery-item-12
    grid-column 14 / -1
    grid-row 4 / 6

  .dummy-gallery-item-13
    grid-column 12 / -1
    grid-row 6 / 13

  .dummy-gallery-item-14
    grid-column 12 / -1
    grid-row 13 / -1
</style>
{/* dummy */}