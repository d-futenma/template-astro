---
// @ts-nocheck
import { siteTitle, siteDescription, siteUrl, ogImg, ogSiteName, ogType } from '../variables'
import '../styles/style.styl'
import SvgSprites from '../components/SvgSprites.astro'
import Loader from '../components/Loader.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const {
  siteTitle = siteTitle[0],
  description = siteDescription[0],
  ogTitle = siteTitle[1] ?? siteTitle[0],
  ogDescription = siteDescription[1] ?? siteDescription[0],
  ogUrl = siteUrl,
  ogImg,
  bodyClass
} = Astro.props
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:type" content={ogType} />
    <link rel="shortcut icon" type="image/ico" href='/assets/img/favicon/favicon.ico'>
    <script src="../scripts/main.js"></script>
  </head>
  <body class={bodyClass}>
    <SvgSprites />
    <Loader />
    <div class="wrapper">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
