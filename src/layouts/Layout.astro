---
// @ts-nocheck
import { siteTitle, siteDescription, siteUrl, ogImg, ogSiteName, ogType, dirImg } from '../site.config'
import '../styles/style.styl'
import SvgSprites from '../components/SvgSprites.astro'
import Header from './Header.astro'
import Footer from './Footer.astro'

const {
  title = siteTitle[0],
  description = siteDescription[0],
  ogTitle = siteTitle[1] ?? siteTitle[0],
  ogDescription = siteDescription[1] ?? siteDescription[0],
  ogUrl = siteUrl,
  ogImg,
  bodyClass
} = Astro.props
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:type" content={ogType} />
    <link rel="shortcut icon" type="image/ico" href={`${dirImg}favicon/favicon.svg`}>
    <script src="../scripts/main.js"></script>
  </head>
  <body class={bodyClass}>
    <SvgSprites />
    <div class="wrapper">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

