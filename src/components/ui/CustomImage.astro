---
import config from '../../site-config';
import extractFileDetails from '../../utilities/extractFileDetails';
import normalizeSlashes from '../../utilities/normalizeSlashes';
import optimizeImage from '../../utilities/optimizeImage';

const { src, alt = '', loading = config.images.loading, decoding = config.images.decoding, format = config.images.format, ...otherProps } = Astro.props;
const { ext } = extractFileDetails(src);
const isSvg = ext === 'svg';
const importedImages = import.meta.glob('/src/assets/img/**/*');

const optimize = async () => {
  const imagePath = normalizeSlashes(`/src${src}`)
  const optimizedImage = await optimizeImage(imagePath, importedImages, isSvg, format)
  return { optimizedImage };
};

const { optimizedImage } = await optimize();
---

<img
  src={optimizedImage.src}
  alt={alt}
  width={isSvg ? optimizedImage.width : optimizedImage.attributes.width}
  height={isSvg ? optimizedImage.height : optimizedImage.attributes.height}
  loading={loading}
  decoding={decoding}
  {...otherProps}
/>