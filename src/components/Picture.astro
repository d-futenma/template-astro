---
import imageSize from 'image-size';
import config from '../config';

interface ImageProps {
  src: string;
  alt: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'sync' | 'async' | 'auto';
  retina?: boolean;
}

const { src, alt, loading = 'lazy', decoding = 'async', retina = true } = Astro.props as ImageProps;
const { breakPoint, path } = config;

const ext = src.split('.').pop()?.toLowerCase();

const imagePath = (sizePrefix = ''): string => {
  return `${path.image.dir}${sizePrefix}${src}`.replace(/\/+/g, '/')
}

const retinaImagePath = (sizePrefix = ''): string => {
  const retinaFilename = src.replace(`.${ext}`, `@2x.${ext}`).split('/').pop();
  return `${path.image.dir}${sizePrefix}${retinaFilename}`.replace(/\/+/g, '/');
}

const imageSizes = (path: string) => imageSize(`public${path}`);

const mdImageSizes = imageSizes(imagePath(path.image.md));
const smImageSizes = imageSizes(imagePath(path.image.sm));
---

<picture>
  <source
    media={`(min-width: ${breakPoint.md}px)`}
    srcset={`${imagePath(path.image.md)}${retina ? `, ${retinaImagePath(path.image.md)} 2x` : ''}`}
    width={smImageSizes.width}
    height={smImageSizes.height}
  />
  <img
    src={imagePath(path.image.sm)}
    alt={alt}
    width={mdImageSizes.width}
    height={mdImageSizes.height}
    loading={loading}
    decoding={decoding}
  />
</picture>